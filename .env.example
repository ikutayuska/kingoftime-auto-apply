# Required
KOT_USERNAME=your_login_id
KOT_PASSWORD=your_password

# Optional: override if needed
KOT_URL=https://login.ta.kingoftime.jp/admin
KOT_TIMEZONE=Asia/Tokyo
KOT_HEADLESS=false
# e.g. chrome, msedge. Leave empty to use bundled Chromium.
KOT_BROWSER_CHANNEL=

# Comma-separated keywords used for location detection
KOT_OFFICE_KEYWORDS=OfficeAreaKeyword1,OfficeAreaKeyword2
KOT_REMOTE_KEYWORDS=RemoteAreaKeyword1,RemoteAreaKeyword2

# Remarks for each request type
KOT_TRANSIT_REMARK=Commuting expense request
KOT_REMOTE_REMARK=Remote allowance request
